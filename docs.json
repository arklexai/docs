{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Arkdock",
  "colors": {
    "primary": "#035e7b",
    "light": "#e6f2f6",
    "dark": "#024d65"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@arklex.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://arkdock.arklex.ai/platform/login"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/arklexai",
      "github": "https://github.com/arklexai",
      "linkedin": "https://linkedin.com/company/arklexai"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "overview",
          "quickstart",
          "faq"
        ]
      },
      {
        "group": "Core Features",
        "pages": [
          "agents",
          "scenarios",
          "simulations",
          "evaluations",
          "annotations",
          "knowledge",
          "metrics"
        ]
      },
      {
        "group": "Team Management",
        "pages": ["settings"]
      },
      {
        "group": "Advanced",
        "pages": ["metric-alignment"]
      },
      {
        "group": "Help",
        "pages": ["support"]
      }
    ]
  }
}
